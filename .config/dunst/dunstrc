[global]
    # --- Tampilan Utama ---
    monitor = 0
    follow = mouse
    width = 300
    height = 300
    origin = top-right
    offset = 10x30
    scale = 0
    notification_limit = 5

    # --- Transparansi & Warna ---
    # transparency: 0-100 (0=opaque, 100=invisible)
    # Gunakan compositor (picom) untuk hasil terbaik
    transparency = 10 
    separator_height = 2
    padding = 10
    horizontal_padding = 10
    text_icon_padding = 10
    frame_width = 2
    
    # Border & Warna Transparan (RGBA atau Hex)
    # Latar belakang hitam transparan
    background = "#1a1a1a" 
    foreground = "#eeeeee"
    frame_color = "#333333"
    separator_color = frame

    # --- Font & Tampilan ---
    font = DejaVu Sans Medium 10
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    # --- Ikon ---
    icon_position = left
    min_icon_size = 32
    max_icon_size = 32
    icon_path = /usr/share/icons/Adwaita/16x16/status/:/usr/share/icons/Adwaita/16x16/devices/

    # --- Perilaku ---
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/firefox -new-tab
    always_run_script = true
    title = Dunst
    class = Dunst

[urgency_low]
    background = "#1a1a1a"
    foreground = "#888888"
    frame_color = "#222222"
    timeout = 5

[urgency_normal]
    background = "#1a1a1a"
    foreground = "#eeeeee"
    frame_color = "#444444"
    timeout = 10

[urgency_critical]
    background = "#1a1a1a"
    foreground = "#ffffff"
    frame_color = "#ff5555" # Merah sedikit untuk notifikasi kritis
    timeout = 0

